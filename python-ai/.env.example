# === ISTA AI - Environment Variables ===

# Internal service token (must match Laravel's AI_SERVICE_TOKEN)
AI_SERVICE_TOKEN=your_internal_api_secret

# Primary: Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key

# Fallback 1: GitHub Models (Primary)
GITHUB_TOKEN=your_github_token

# Fallback 2: GitHub Models (Backup) - for 2M TPM capacity
GITHUB_TOKEN_2=your_github_token_2

# Fallback 3: Groq Cloud
GROQ_API_KEY=your_groq_api_key

# === Token-Aware Chunking Configuration (Update Tahap 5) ===
# Token-based chunking using tiktoken (cl100k_base)
TOKEN_CHUNK_SIZE=1500  # Max tokens per chunk (default: 1500)
TOKEN_CHUNK_OVERLAP=150  # Token overlap between chunks (default: 150)

# Smart Batching Configuration
# IMPORTANT: OpenAI embedding API has 64K tokens per request limit
# Smart batching will automatically split batches to stay under 60K tokens
AGGRESSIVE_BATCH_SIZE=200  # Max chunks per batch (default: 200)
BATCH_DELAY_SECONDS=0.5  # Delay between batches in seconds (default: 0.5)

# Recommended settings for large documents (>500KB):
# TOKEN_CHUNK_SIZE=1200
# AGGRESSIVE_BATCH_SIZE=50
# BATCH_DELAY_SECONDS=1.0

# Embedding timeout
EMBEDDING_TIMEOUT=30

# LangSearch API (Free Web Search)
# Register at https://langsearch.com/api-keys
LANGSEARCH_API_KEY=your_langsearch_api_key
LANGSEARCH_API_KEY_BACKUP=your_langsearch_api_key_backup
LANGSEARCH_TIMEOUT=10
LANGSEARCH_CACHE_TTL=300  # Cache duration in seconds (default: 5 minutes)

# LangSearch Semantic Rerank API (optional)
LANGSEARCH_RERANK_ENABLED=true
LANGSEARCH_RERANK_MODEL=langsearch-reranker-v1
LANGSEARCH_RERANK_TIMEOUT=8
LANGSEARCH_RERANK_MAX_DOCS=50
LANGSEARCH_RERANK_CACHE_TTL=300

# Rerank tuning parameters
LANGSEARCH_RERANK_DOC_CANDIDATES=20
LANGSEARCH_RERANK_DOC_TOP_N=5
LANGSEARCH_RERANK_WEB_CANDIDATES=10
LANGSEARCH_RERANK_WEB_TOP_N=5
LANGSEARCH_RERANK_MIN_SCORE=0.15

# Default system prompt (optional, can be overridden by Laravel)
DEFAULT_SYSTEM_PROMPT=Anda adalah ISTA AI, asisten virtual istana pintar. Jawablah dengan sopan dan membantu.
