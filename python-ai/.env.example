# === ISTA AI — Python AI Service Environment Variables ===
#
# File ini HANYA untuk menyimpan rahasia (API keys & token).
# Konfigurasi non-rahasia dikelola di: config/ai_config.yaml
#
# Hierarki prioritas konfigurasi:
#   .env (override, prioritas tertinggi) → ai_config.yaml → hardcoded default

# ─────────────────────────────────────────────────────────
# KEAMANAN INTERNAL
# ─────────────────────────────────────────────────────────
# WAJIB sama persis dengan AI_SERVICE_TOKEN di laravel/.env
AI_SERVICE_TOKEN=your_internal_api_secret

# ─────────────────────────────────────────────────────────
# LLM & EMBEDDING API KEYS
# ─────────────────────────────────────────────────────────
# Google AI Studio (Gemini fallback)
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key

# GitHub Models — Primary & Backup (LLM + Embedding)
GITHUB_TOKEN=your_github_token
GITHUB_TOKEN_2=your_github_token_2

# Groq Cloud (fallback LLM)
GROQ_API_KEY=your_groq_api_key

# ─────────────────────────────────────────────────────────
# WEB SEARCH API KEYS
# ─────────────────────────────────────────────────────────
LANGSEARCH_API_KEY=your_langsearch_api_key
LANGSEARCH_API_KEY_BACKUP=your_langsearch_api_key_backup
