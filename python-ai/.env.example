# === ISTA AI - Environment Variables ===

# Internal service token (must match Laravel's AI_SERVICE_TOKEN)
AI_SERVICE_TOKEN=your_internal_api_secret

# Primary: Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_API_KEY=your_google_api_key

# Fallback 1: GitHub Models
GITHUB_TOKEN=your_github_token

# Fallback 2: Groq Cloud
GROQ_API_KEY=your_groq_api_key

# Embedding API Keys
JINA_API_KEY=your_jina_api_key
QWEN_API_KEY=your_qwen_api_key

# LangSearch API (Free Web Search)
# Register at https://langsearch.com/api-keys
LANGSEARCH_API_KEY=your_langsearch_api_key
LANGSEARCH_TIMEOUT=10
LANGSEARCH_CACHE_TTL=300  # Cache duration in seconds (default: 5 minutes)

# Default system prompt (optional, can be overridden by Laravel)
DEFAULT_SYSTEM_PROMPT=Anda adalah ISTA AI, asisten virtual istana pintar. Jawablah dengan sopan dan membantu.
