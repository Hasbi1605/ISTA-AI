APP_NAME="ISTA AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=istanaai
DB_USERNAME=root
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Gmail SMTP (mailer profile "gmail" di config/mail.php).
# Untuk pakai: set MAIL_MAILER=gmail dan isi kredensial di bawah.
# WAJIB pakai App Password Google (16 karakter), BUKAN password akun.
# Cara generate App Password: https://myaccount.google.com/apppasswords
# MAIL_GMAIL_HOST=smtp.gmail.com
# MAIL_GMAIL_PORT=587
# MAIL_GMAIL_ENCRYPTION=tls
# MAIL_GMAIL_USERNAME=
# MAIL_GMAIL_PASSWORD=

# Reasoning lane (parity dengan lanes.reasoning di python-ai). Default off;
# isi dengan model reasoning seperti DeepSeek R1 untuk eksperimen.
# AI_REASONING_CASCADE_ENABLED=false

AUTH_OTP_REGISTRATION_TTL_MINUTES=60
AUTH_OTP_REGISTRATION_MAX_ATTEMPTS=3
AUTH_OTP_REGISTRATION_DECAY_SECONDS=600
AUTH_OTP_REGISTRATION_RESEND_COOLDOWN_SECONDS=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# AI Service Configuration (Laravel AI SDK)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=30
AI_CONNECT_TIMEOUT=10
AI_READ_TIMEOUT=120

# Multi-Provider Cascade (GitHub Models, Groq, Gemini)
AI_CASCADE_ENABLED=true
GITHUB_TOKEN=
GITHUB_TOKEN_2=
GROQ_API_KEY=
GEMINI_API_KEY=

# AI Feature Flags
AI_WEB_SEARCH_ENABLED=true
AI_WEB_SEARCH_PROVIDER=ddg
AI_DOCUMENT_PROCESS_ENABLED=true
AI_DOCUMENT_SUMMARIZE_ENABLED=true
AI_DOCUMENT_DELETE_ENABLED=true
AI_DOCUMENT_RETRIEVAL_ENABLED=true
AI_USE_PROVIDER_FILE_SEARCH=true

# AI Runtime Configuration (laravel OR python)
AI_RUNTIME_CHAT=laravel
AI_RUNTIME_DOCUMENT_RETRIEVAL=laravel
AI_RUNTIME_DOCUMENT_PROCESS=laravel
AI_RUNTIME_DOCUMENT_SUMMARIZE=laravel
AI_RUNTIME_DOCUMENT_DELETE=laravel
AI_SHADOW_ENABLED=false
AI_SHADOW_LOG_PARITY=false

# Legacy Python AI Service (for emergency rollback only)
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_TOKEN=your_internal_api_secret
